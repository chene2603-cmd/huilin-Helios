;==========================================================
; Helios OS 引导扇区
; 功能: 从实模式切换到保护模式，加载内核
;==========================================================

[bits 16]                ; 告诉汇编器生成16位代码
[org 0x7c00]             ; BIOS加载引导扇区到0x7c00

KERNEL_OFFSET equ 0x1000 ; 内核加载地址

start:
    ; 设置段寄存器
    cli                  ; 禁用中断
    mov ax, 0x00
    mov ds, ax
    mov es, ax
    mov ss, ax
    mov sp, 0x7c00       ; 设置栈指针

    ; 保存引导设备
    mov [BOOT_DRIVE], dl

    ; 显示启动信息
    mov si, MSG_LOAD_KERNEL
    call print_string

    ; 加载内核到内存
    mov bx, KERNEL_OFFSET
    mov dh, 15           ; 读取15个扇区
    mov dl, [BOOT_DRIVE]
    call disk_load

    ; 切换到保护模式
    call switch_to_pm

    jmp $                ; 永远不会执行到这里

;==========================================================
; 实模式函数
;==========================================================

; 打印字符串
; 输入: SI = 字符串地址
print_string:
    pusha
    mov ah, 0x0E         ; BIOS 打印字符功能
.print_char:
    lodsb                ; 加载SI指向的字符到AL
    cmp al, 0
    je .done
    int 0x10             ; BIOS视频中断
    jmp .print_char
.done:
    popa
    ret

; 从磁盘加载数据
; 输入: DH = 扇区数, DL = 驱动器号, ES:BX = 目标地址
disk_load:
    pusha
    push dx

    mov ah, 0x02         ; BIOS读扇区功能
    mov al, dh           ; 读取的扇区数
    mov ch, 0x00         ; 柱面0
    mov dh, 0x00         ; 磁头0
    mov cl, 0x02         ; 从第二个扇区开始（第一个是引导扇区）

    int 0x13             ; BIOS磁盘中断
    jc disk_error        ; 如果出错

    pop dx
    cmp dh, al           ; 比较读取的扇区数
    jne disk_error
    
    popa
    ret

disk_error:
    mov si, MSG_DISK_ERROR
    call print_string
    jmp $

;==========================================================
; 切换到保护模式
;==========================================================
switch_to_pm:
    cli                  ; 禁用中断

    ; 加载GDT
    lgdt [gdt_descriptor]

    ; 设置保护模式位
    mov eax, cr0
    or eax, 0x1
    mov cr0, eax

    ; 远跳转以清空流水线
    jmp CODE_SEG:init_pm

[bits 32]
; 保护模式初始化
init_pm:
    ; 设置段寄存器
    mov ax, DATA_SEG
    mov ds, ax
    mov ss, ax
    mov es, ax
    mov fs, ax
    mov gs, ax
    mov esp, 0x90000     ; 设置栈指针

    ; 跳转到内核
    call KERNEL_OFFSET

    jmp $                ; 防止返回

;==========================================================
; 全局描述符表
;==========================================================
gdt_start:

; 空描述符
gdt_null:
    dd 0x0
    dd 0x0

; 代码段描述符
gdt_code:
    ; 基地址=0x0, 界限=0xfffff
    dw 0xffff           ; 段界限 (0-15)
    dw 0x0              ; 基地址 (0-15)
    db 0x0              ; 基地址 (16-23)
    ; 权限: 存在=1, 特权级=00, 描述符类型=1, 代码=1, 可读=1, 访问=0
    db 10011010b        ; 类型标志
    ; 标志: 粒度=1, 32位=1, 64位=0, AVL=0
    db 11001111b        ; 段界限+标志
    db 0x0              ; 基地址 (24-31)

; 数据段描述符
gdt_data:
    dw 0xffff           ; 段界限
    dw 0x0              ; 基地址
    db 0x0              ; 基地址
    ; 权限: 存在=1, 特权级=00, 描述符类型=1, 代码=0, 可写=1, 访问=0
    db 10010010b        ; 类型标志
    db 11001111b        ; 段界限+标志
    db 0x0              ; 基地址

gdt_end:

; GDT描述符
gdt_descriptor:
    dw gdt_end - gdt_start - 1
    dd gdt_start

; 段选择子
CODE_SEG equ gdt_code - gdt_start
DATA_SEG equ gdt_data - gdt_start

;==========================================================
; 数据
;==========================================================
BOOT_DRIVE db 0
MSG_LOAD_KERNEL db "Loading Helios kernel...", 0x0D, 0x0A, 0
MSG_DISK_ERROR db "Disk read error!", 0x0D, 0x0A, 0

; 填充到512字节，末尾为魔数
times 510-($-$$) db 0
dw 0xaa55